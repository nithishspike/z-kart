package com.nitish;

class Demo{
	public int a, b;
	Demo(int a, int b){
		this.a = a;
		this.b = b;
	}
	
	@Override
	public String toString() {
		// TODO Auto-generated method stub
		return "a = " + a + ", b = " + b;
	}
}

public class Main {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		Demo a = new Demo(10, 11);
		Demo b = a;
		
		System.out.println(a);
		System.out.println(b);
		
		a.a = 1000;
		a.b = 1223;
		
		System.out.println(a);
		System.out.println(b);
        
	}

}
